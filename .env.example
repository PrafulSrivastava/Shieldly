# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ─────────────────────────────────────────────
# Database (PostgreSQL via asyncpg)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shieldher:shieldher@localhost:5432/shieldher

# ─────────────────────────────────────────────
# Cache / Pub-Sub (Redis)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─────────────────────────────────────────────
# Firebase (Phone OTP)
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-web-api-key

# ─────────────────────────────────────────────
# Twilio (SMS)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─────────────────────────────────────────────
# Google Maps
# ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─────────────────────────────────────────────
# Gemini AI
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────
# ElevenLabs (Conversational AI)
# ─────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id

# ─────────────────────────────────────────────
# Mock toggles (set to "true" to skip real API calls)
# ─────────────────────────────────────────────
MOCK_FIREBASE=false
MOCK_SMS=false
MOCK_MAPS=false
MOCK_GEMINI=false
MOCK_PUSH=true        # Set to false to send real Expo push notifications
MOCK_ELEVENLABS=true  # Set to false to get real ElevenLabs signed URLs

# Testing — separate DB so tests never touch the dev DB
# Use localhost:5433 when running pytest outside Docker; db:5432 inside Docker
TEST_DATABASE_URL=postgresql+asyncpg://shieldher:shieldher@localhost:5433/shieldher_test
